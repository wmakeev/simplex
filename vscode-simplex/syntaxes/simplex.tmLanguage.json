{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "SimplEx",
  "scopeName": "source.simplex",
  "patterns": [
    { "include": "#comments" },
    { "include": "#template-literal" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#constants" },
    { "include": "#keywords" },
    { "include": "#keyword-operators" },
    { "include": "#operators" },
    { "include": "#special-variables" },
    { "include": "#lambda-arrow" },
    { "include": "#identifiers" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.simplex",
          "match": "//.*$"
        },
        {
          "name": "comment.block.simplex",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.simplex",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.simplex",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.simplex",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.simplex",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "template-literal": {
      "name": "string.interpolated.simplex",
      "begin": "`",
      "end": "`",
      "patterns": [
        {
          "name": "constant.character.escape.simplex",
          "match": "\\\\."
        },
        {
          "begin": "\\$\\{",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.interpolation.begin.simplex" }
          },
          "end": "\\}",
          "endCaptures": {
            "0": { "name": "punctuation.definition.interpolation.end.simplex" }
          },
          "contentName": "meta.interpolation.simplex",
          "patterns": [
            { "include": "source.simplex" }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.simplex",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.simplex",
          "match": "\\b[0-9]*\\.?[0-9]+([eE][+-]?[0-9]+)?\\b"
        }
      ]
    },
    "constants": {
      "name": "constant.language.simplex",
      "match": "\\b(true|false|null|undefined)\\b"
    },
    "keywords": {
      "name": "keyword.control.simplex",
      "match": "\\b(if|then|else|let)\\b"
    },
    "keyword-operators": {
      "name": "keyword.operator.word.simplex",
      "match": "\\b(and|or|not|in|mod|typeof)\\b"
    },
    "lambda-arrow": {
      "name": "storage.type.function.arrow.simplex",
      "match": "=>"
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.pipe.simplex",
          "match": "\\|>|\\|\\?"
        },
        {
          "name": "keyword.operator.nullish.simplex",
          "match": "\\?\\?"
        },
        {
          "name": "keyword.operator.comparison.simplex",
          "match": "==|!=|<=|>="
        },
        {
          "name": "keyword.operator.logical.simplex",
          "match": "&&|\\|\\|"
        },
        {
          "name": "keyword.operator.extension.simplex",
          "match": "::"
        },
        {
          "name": "keyword.operator.simplex",
          "match": "[+\\-*/^&|<>=!]"
        }
      ]
    },
    "special-variables": {
      "patterns": [
        {
          "name": "variable.language.placeholder.simplex",
          "match": "#"
        },
        {
          "name": "variable.language.topic.simplex",
          "match": "%"
        }
      ]
    },
    "identifiers": {
      "name": "variable.other.simplex",
      "match": "[a-zA-Z_$][a-zA-Z0-9_$]*"
    },
    "punctuation": {
      "name": "punctuation.simplex",
      "match": "[()\\[\\]{},.:?]"
    }
  }
}
